# Shopify Admin API credentials
# To get these:
# 1. Go to your Shopify Admin: https://signfire-fine-art.myshopify.com/admin
# 2. Navigate to Settings > Apps and sales channels > Develop apps
# 3. Create a new app (or use an existing one)
# 4. Under "Configuration", set Admin API access scopes:
#    - read_products
#    - read_product_listings
#    - read_inventory
# 5. Install the app, then copy the Admin API access token

SHOPIFY_STORE=signfire-fine-art.myshopify.com
SHOPIFY_ACCESS_TOKEN=shpat_xxxxxxxxxxxxxxxxxxxxxxxxxxxxx
